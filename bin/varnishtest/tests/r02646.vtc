vtest "#2646: VUT should fail gracefully when removing a pid file fails"

vinyl v1 -vcl {
	backend be {
		.host = "${bad_backend}";
	}
} -start

process p1 {
	exec vinylncsa -n ${v1_name} -P ${tmpdir}/ncsa.pid -w ${tmpdir}/ncsa.log
} -start

delay 1

shell "rm -f ${tmpdir}/ncsa.pid"

process p1 -stop -wait
