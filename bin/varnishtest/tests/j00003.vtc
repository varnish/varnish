vtest "-junix bad subarg handling"

feature root

shell -err -expect "unknown sub-argument" "vinyld -junix,bla=foo -f ''"
shell -err -expect "user not found" "vinyld -junix,user=/// -f ''"
shell -err -expect "user not found" "vinyld -junix,workuser=/// -f ''"
shell -err -expect "group not found" "vinyld -junix,ccgroup=/// -f ''"

feature user_varnish

shell -err -expect "have different login groups" "vinyld -junix,workuser=root -f ''"
