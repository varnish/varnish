vtest "ban expression object name prefixes"

server s1 {} -start

vinyl v1 -vcl+backend {} -start


vinyl v1 -cliexpect {Unknown or unsupported field "req.urlXX"} "ban req.urlXX ~ foobarbazzz"
vinyl v1 -cliexpect {Unknown or unsupported field "obj.ageYY"} "ban obj.ageYY < 1d"
vinyl v1 -cliexpect {Unknown or unsupported field "req.ur"} "ban req.ur ~ foobarbazzz"
vinyl v1 -cliexpect {Unknown or unsupported field "req.htt"} "ban req.htt ~ foobarbazzz"
vinyl v1 -cliexpect {Unknown or unsupported field "req.htt.XXYY"} "ban req.htt.XXYY ~ foobarbazzz"
vinyl v1 -cliexpect {Missing header name: "obj.http."} "ban obj.http. ~ foobarbazzz"
vinyl v1 -cliok "ban req.http.XXYY ~ foobarbazzz"
