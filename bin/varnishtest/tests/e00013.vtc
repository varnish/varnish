vtest "All white-space object, in multiple storage segments"

server s1 {
	rxreq
	expect req.url == "/foo"
	txresp -nolen -hdr "Transfer-Encoding: chunked"
	chunked {<x>                                      }
	chunkedlen 0
} -start

vinyl v1 -vcl+backend {
	sub vcl_backend_response {
		set beresp.do_esi = true;
	}
} -start

vinyl v1 -cliok "debug.fragfetch 4"

client c1 {
	txreq -url /foo
	rxresp
} -run

vinyl v1 -expect esi_errors == 0
