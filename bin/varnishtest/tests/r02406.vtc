vtest "Long backend and storage names"

vinyl v1 -arg "-s acme_example_com_static_assets_default_storage=default"

vinyl v1 -vcl {
	backend be_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789 {
		.host = "${bad_backend}";
	}
} -start

vinyl v1 -expect SM?.acme_example_com_static_assets_default_storage.c_req == 0
vinyl v1 -expect VBE.vcl1.be_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789_0123456789.req == 0
