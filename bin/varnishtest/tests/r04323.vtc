vtest "parameter alias bypassing protection"

vinyl v1 -arg "-r vcc_feature"

vinyl v1 -clierr 107 "param.set vcc_feature all"
vinyl v1 -clierr 107 "param.set vcc_allow_inline_c on"

shell -err -expect "Cannot mark alias vcc_allow_inline_c read only" {
	vinyld -d -r vcc_allow_inline_c -n ${tmpdir}/vd
}
