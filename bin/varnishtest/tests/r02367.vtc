vtest "POST and return(vcl(..))"

server s1 {
	rxreq
	expect req.bodylen == 4
	txresp
} -start

vinyl v1 -vcl+backend {} -start
vinyl v1 -cliok "vcl.label vclA vcl1"

vinyl v1 -vcl+backend {
	sub vcl_recv {
		return (vcl(vclA));
	}
}

client c1 {
	txreq -req POST -body "asdf"
	rxresp
	expect resp.status == 200
} -run
