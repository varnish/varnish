vtest "Count purges when there are many variants"

server s1 -repeat 72 -keepalive {
	rxreq
	txresp -hdr "Vary: X-Vinyl"
} -start

vinyl v1 -arg "-p workspace_thread=512" -vcl+backend {
	sub vcl_recv {
		if (req.method == "PURGE") {
			return (purge);
		}
	}
} -start

logexpect l1 -v v1 {
	expect * * Notice "High number of variants .71."
} -start

client c1 -repeat 72 -keepalive {
	txreq
	rxresp
} -run

logexpect l1 -wait

client c2 {
	txreq -req "PURGE"
	rxresp
} -run

vinyl v1 -expect n_lru_nuked == 0
vinyl v1 -expect cache_hit == 0
vinyl v1 -expect n_purges == 1
vinyl v1 -expect n_obj_purged == 72
