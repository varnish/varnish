vtest "h2 CONTINUATION flood"

vinyl v1 -cliok "param.set feature +http2"
vinyl v1 -cliok "param.set vsl_mask -H2RxHdr,-H2RxBody"
vinyl v1 -vcl { backend be none; } -start

client c1 {
	non_fatal
	stream next {
		txreq -nohdrend
		loop 1000 {
			txcont -nohdrend -hdr noise ${string,repeat,4096,x}
		}
		txcont -hdr last header
	} -run
} -run

vinyl v1 -expect MAIN.s_req_hdrbytes < 65536
vinyl v1 -expect MAIN.sc_overload == 1
