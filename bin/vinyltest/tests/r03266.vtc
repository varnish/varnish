vtest "Don't recycle a closed backend connection"

# broken origin: sends eof-encoded HTTP/1.1 response
server s1 {
	rxreq
	send "HTTP/1.1 200 OK\r\n\r\n"
	send "foobar"
} -start

vinyl v1 -vcl+backend {} -start

client c1 {
	txreq
	rxresp
} -run

vinyl v1 -expect fetch_failed == 0
vinyl v1 -expect fetch_eof == 1
vinyl v1 -expect backend_recycle == 0
