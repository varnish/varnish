vtest "Whitespace after colon is optional"

server s1 {
	rxreq
	txresp
} -start

vinyl v1 -vcl+backend {} -start

client c1 {
	txreq -hdr "Host:qux" -hdr "Authorization:Basic Zm9vOmJhcg=="
	rxresp
} -run

delay 1

shell -expect "foo qux" \
	{vinylncsa -d -n ${v1_name} -F "%u %{Host}i"}
shell -expect "GET http://qux/ HTTP/1.1" \
	{vinylncsa -d -n ${v1_name} -F "%r"}
