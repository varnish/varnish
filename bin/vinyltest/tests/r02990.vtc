vtest "Initial vinylstat verbosity"

vinyl v1 -vcl {backend be none;} -start

process p1 -dump {vinylstat -n ${v1_name}} -start
process p2 -dump {vinylstat -n ${v1_name} -f MGT.child_start} -start

process p1 -expect-text 0 0 INFO
process p1 -screen_dump

process p2 -expect-text 0 0 MGT.child_start
process p2 -expect-text 0 0 DIAG
process p2 -screen_dump
