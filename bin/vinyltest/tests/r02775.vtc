vtest "Regression test for #2775: allow PRIORITY on closed stream"

server s1 {
	rxreq
	txresp
} -start

vinyl v1 -vcl+backend {} -start
vinyl v1 -cliok "param.set feature +http2"
vinyl v1 -cliok "param.set debug +syncvsl"

client c1 {
	stream 1 {
		txreq
		rxresp

		txprio
	} -run
	stream 3 {
		txreq
		rxresp
	} -run
} -run
